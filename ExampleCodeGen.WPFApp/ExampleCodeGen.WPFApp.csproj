  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Extended.Wpf.Toolkit" Version="5.0.0" />
    <PackageReference Include="MoonSharp" Version="2.0.0.0" />
    <PackageReference Include="ReactiveUI" Version="23.1.8" />
  </ItemGroup>
</Project>
